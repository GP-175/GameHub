{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gamehub",
  "compatibility_date": "2026-04-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "server.js",
  "kv_namespaces": [
    { "binding": "GAMEHUB_STATE", "id": "REPLACE_WITH_REAL_KV_ID" }
  ]
}
